rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // স্মার্ট হেল্পার ফাংশন: ইউজার এডমিন কিনা তা চেক করবে
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'imran.info.me@gmail.com';
    }

    // ══════════════════════════════════════
    // ১. প্রজেক্ট (এখন collaborative — owner অথবা collaborator হলে এক্সেস পাবে)
    // ══════════════════════════════════════
    match /projects/{projectId} {

      function isOwner() {
        return request.auth != null && resource.data.ownerUid == request.auth.uid;
      }

      function isCollaborator() {
        return request.auth != null &&
          resource.data.collaboratorUids != null &&
          request.auth.uid in resource.data.collaboratorUids;
      }

      // ── নতুন কেউ শেয়ার লিংক দিয়ে জয়েন করার সময়, নিজে owner/collaborator
      //    না হয়েও শুধুমাত্র নিজের uid-টা collaboratorUids-এ যোগ করতে পারবে।
      //    অন্য কারো uid যোগ/বাদ দেওয়া বা লিস্টের অন্য এন্ট্রি বদলানো যাবে না। ──
      function isSelfJoining() {
        return request.auth != null &&
          !isOwner() && !isCollaborator() &&
          request.resource.data.collaboratorUids != null &&
          request.resource.data.collaboratorUids.hasAll(resource.data.collaboratorUids) &&
          request.resource.data.collaboratorUids.size() == resource.data.collaboratorUids.size() + 1 &&
          request.auth.uid in request.resource.data.collaboratorUids;
      }

      allow read: if request.auth != null &&
        (resource.data.ownerUid == request.auth.uid ||
         request.auth.uid in resource.data.collaboratorUids);

      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;

      allow update: if request.auth != null &&
        (isOwner() || isCollaborator() || isSelfJoining()) &&
        request.resource.data.ownerUid == resource.data.ownerUid; // owner বদলানো যাবে না

      // ── শুধু owner ডিলিট করতে পারবে — এডিটর হিসেবে যোগ দেওয়া কোলাবোরেটর
      //    কখনোই প্রজেক্ট ডিলিট করতে পারবে না ──
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ══════════════════════════════════════
    // ২. শেয়ার লিংক (জয়েন করার জন্য)
    // ══════════════════════════════════════
    match /shareLinks/{shareId} {
      allow read: if request.auth != null;   // যেকোনো লগইন ইউজার validate করতে পারবে

      allow create: if request.auth != null &&
        request.resource.data.createdBy == request.auth.uid;

      allow update: if request.auth != null &&
        resource.data.createdBy == request.auth.uid;   // শুধু creator deactivate করতে পারবে

      allow delete: if false;
    }

    // ══════════════════════════════════════
    // ৩. ইউজার প্রোফাইল / denormalized প্রজেক্ট লিস্ট
    // ══════════════════════════════════════
    match /users/{uid} {
      // এখানে স্পষ্টভাবে delete করার পারমিশন যুক্ত করা হলো
      allow read, create, update, delete: if request.auth != null && request.auth.uid == uid;
    }

    // ══════════════════════════════════════
    // ৩.১ ইউজারনেম → ইমেইল ম্যাপিং (Username দিয়ে Login করার জন্য)
    // ══════════════════════════════════════
    // ডক আইডি সবসময় ছোট হাতের (lowercase) username হবে।
    // ডেটা: { uid, email, createdAt }
    match /usernames/{usernameLower} {

      // ── read সবার জন্য খোলা (এমনকি লগইন না করা ইউজারও) ──
      // এটা জরুরি কারণ Login স্ক্রিনে কেউ username দিলে, sign-in করার
      // আগেই তার email বের করতে এই ডকটা পড়তে হয় (তখনও auth হয়নি)।
      // এখানে শুধু uid + email থাকে, পাসওয়ার্ড বা অন্য sensitive data থাকে না।
      allow read: if true;

      // ── create: শুধুমাত্র লগইন করা ইউজার, এবং শুধু নিজের uid দিয়েই
      //    একটা username claim করতে পারবে (অন্যের নামে username বানাতে পারবে না) ──
      allow create: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;

      // ── update বন্ধ — username বদলাতে হলে পুরনো ডকটা delete করে
      //    নতুন একটা create করা হয় (কোড এভাবেই কাজ করে) ──
      allow update: if false;

      // ── delete: শুধু যে uid এই username-টা owns করে, সে-ই মুছতে পারবে
      //    (username পরিবর্তন করার সময় পুরনোটা মুছে ফেলার জন্য দরকার) ──
      allow delete: if request.auth != null &&
        resource.data.uid == request.auth.uid;
    }

    // ══════════════════════════════════════
    // ৩.২ ইমেইল → uid ম্যাপিং (ইমেইল দিয়ে প্রজেক্টে কাউকে Invite করার জন্য)
    // ══════════════════════════════════════
    // ডক আইডি সবসময় ছোট হাতের (lowercase) email। ডেটা: { uid }
    match /userEmails/{emailLower} {

      // ── read সবার জন্য খোলা — কেউ প্রজেক্ট শেয়ার করতে গিয়ে টার্গেট
      //    ইউজারের ইমেইল দিলে, তার uid বের করতে এই ডকটা পড়তে হয়। এখানে
      //    শুধু uid থাকে, ইমেইল/পাসওয়ার্ড কিছুই এক্সপোজ হয় না। ──
      allow read: if true;

      allow create: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;

      allow update: if false;

      allow delete: if request.auth != null &&
        resource.data.uid == request.auth.uid;
    }

    // ══════════════════════════════════════
    // ৩.৩ পাবলিক প্রোফাইল (কোলাবোরেটর লিস্টে নাম/ছবি দেখানোর জন্য)
    // ══════════════════════════════════════
    // ডক আইডি = uid। ডেটা: { username, displayName, photoURL, updatedAt }
    match /publicProfiles/{uid} {

      // ── read সবার জন্য খোলা — শেয়ার মোডালে "কে কে প্রজেক্টে আছে" লিস্টে
      //    অন্যদের নাম/ছবি দেখানোর জন্য দরকার। এখানে ইমেইল থাকে না। ──
      allow read: if true;

      // ── শুধু নিজের প্রোফাইল ডকটাই লিখতে/মুছতে পারবে ──
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ══════════════════════════════════════
    // ৩.৪ রেটিং / রিভিউ (Rate Us পেজ)
    // ══════════════════════════════════════
    // ডক আইডি = uid (একজন ইউজার একটাই রেটিং দিতে/আপডেট করতে পারবে)।
    // ডেটা: { uid, displayName, username, photoURL, rating(1-5), review, createdAt, updatedAt,
    //         loveUids: [uid...], helpfulUids: [uid...] }
    match /ratings/{uid} {

      // ── পুরনো ডকে loveUids/helpfulUids না থাকলে খালি লিস্ট ধরে নেওয়া হবে ──
      function oldLoveUids() {
        return ('loveUids' in resource.data) ? resource.data.loveUids : [];
      }
      function oldHelpfulUids() {
        return ('helpfulUids' in resource.data) ? resource.data.helpfulUids : [];
      }

      // ── শুধু নিজের uid-টা লিস্টে যোগ বা বাদ দেওয়া যাবে, অন্য কারো uid ছোঁয়া যাবে না ──
      function isValidLoveToggle() {
        let newArr = request.resource.data.loveUids;
        let old    = oldLoveUids();
        return newArr is list &&
          (
            (newArr.size() == old.size() + 1 && newArr.hasAll(old) && request.auth.uid in newArr) ||
            (newArr.size() == old.size() - 1 && old.hasAll(newArr) && request.auth.uid in old && !(request.auth.uid in newArr))
          );
      }
      function isValidHelpfulToggle() {
        let newArr = request.resource.data.helpfulUids;
        let old    = oldHelpfulUids();
        return newArr is list &&
          (
            (newArr.size() == old.size() + 1 && newArr.hasAll(old) && request.auth.uid in newArr) ||
            (newArr.size() == old.size() - 1 && old.hasAll(newArr) && request.auth.uid in old && !(request.auth.uid in newArr))
          );
      }

      // ── যেকোনো লগইন ইউজার একটা রিভিউতে love বা helpful টগল করতে পারবে,
      //    কিন্তু শুধু নিজের uid ছাড়া অন্য কিছু (rating/review/অন্য কারো reaction) বদলাতে পারবে না ──
      function isReactionUpdate() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return request.auth != null &&
          (
            (changed.hasOnly(['loveUids']) && isValidLoveToggle()) ||
            (changed.hasOnly(['helpfulUids']) && isValidHelpfulToggle())
          );
      }

      // ── read সবার জন্য খোলা — গড় রেটিং, রিভিউ ফিড ও reaction কাউন্ট দেখানোর জন্য দরকার ──
      allow read: if true;

      // ── শুধু নিজের uid দিয়েই রেটিং create করতে পারবে, rating অবশ্যই ১-৫ এর মধ্যে ──
      allow create: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.uid == uid &&
        request.resource.data.rating is int &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5 &&
        (!('review' in request.resource.data) || request.resource.data.review.size() <= 400);

      // ── নিজের রিভিউ কনটেন্ট আপডেট (owner), অথবা অন্য যেকারো love/helpful টগল ──
      allow update: if request.auth != null &&
        (
          (
            request.auth.uid == uid &&
            request.resource.data.uid == uid &&
            request.resource.data.rating is int &&
            request.resource.data.rating >= 1 &&
            request.resource.data.rating <= 5 &&
            (!('review' in request.resource.data) || request.resource.data.review.size() <= 400)
          ) ||
          isReactionUpdate()
        );

      // ── শুধু নিজের রেটিং মুছে ফেলতে পারবে ──
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ══════════════════════════════════════
    // ৪. Pro Editor প্যানেলের ৪টি কালেকশন (অপরিবর্তিত)
    // ══════════════════════════════════════
    match /pro_links/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pro_posts/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pro_pdfs/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pro_videos/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════
    // ৫. স্মার্ট সিকিউরিটি: গ্লোবাল ফলব্যাক
    // ══════════════════════════════════════
    // উপরের কোনো রুলসের সাথে না মিললে, ডাটাবেসের অন্য যেকোনো অজানা কালেকশনের রিড/রাইট বন্ধ থাকবে।
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
